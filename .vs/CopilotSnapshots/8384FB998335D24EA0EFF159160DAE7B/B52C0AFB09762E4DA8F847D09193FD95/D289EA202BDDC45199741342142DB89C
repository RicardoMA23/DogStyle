:root {
    --primary: #2563eb;
    --primary-hover: #1d4ed8;
    --secondary: #10b981;
    --bg: #f4f7fb;
    --card: #ffffff;
    --text: #1e293b;
    --muted: #64748b;
    --border: #e2e8f0;
    --shadow: 0 10px 25px rgba(15, 23, 42, 0.08);
    --radius: 18px;
}

body {
    font-family: "Segoe UI", sans-serif;
    background: var(--bg);
    color: var(--text);
    margin: 0;
}

/* Layout */

.app-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.app-layout {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem;
    flex: 1;
}

/* Header */

.app-header {
    background: linear-gradient(135deg, #2563eb, #1e40af);
    color: white;
    padding: 1.2rem 2rem;
    box-shadow: var(--shadow);
}

    .app-header h1 {
        margin: 0;
        font-size: 1.5rem;
        font-weight: 700;
    }

/* Sidebar */

.app-nav {
    width: 240px;
}

.nav-main {
    background: white;
    border-radius: var(--radius);
    padding: 1.2rem;
    box-shadow: var(--shadow);
    height: fit-content;
}

    .nav-main .brand {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 1rem;
    }

    .nav-main ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .nav-main li {
        margin-bottom: .4rem;
    }

    .nav-main a {
        display: flex;
        align-items: center;
        text-decoration: none;
        color: var(--text);
        padding: .9rem 1rem;
        border-radius: 12px;
        transition: .25s ease;
        font-weight: 500;
    }

        .nav-main a:hover {
            background: #eff6ff;
            color: var(--primary);
            transform: translateX(4px);
        }

/* Contenido */

.app-main {
    flex: 1;
    background: transparent;
}

/* Cards */

.card {
    background: var(--card);
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
    border: 1px solid rgba(226,232,240,.6);
    margin-bottom: 1.5rem;
}

    .card h4 {
        margin-top: 0;
        margin-bottom: 1rem;
        font-size: 1.15rem;
    }

/* Botones */

.btn {
    border: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: .85rem 1.3rem;
    background: var(--primary);
    color: white;
    border-radius: 12px;
    text-decoration: none;
    cursor: pointer;
    transition: .25s ease;
    font-weight: 600;
}

    .btn:hover {
        background: var(--primary-hover);
        transform: translateY(-2px);
    }

    .btn.secondary {
        background: var(--secondary);
    }

/* Inputs */

input,
select,
textarea,
.form-control {
    width: 100%;
    box-sizing: border-box;
    padding: .9rem 1rem;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #fff;
    font-size: .95rem;
    transition: .2s ease;
}

    input:focus,
    select:focus,
    textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(37,99,235,.15);
    }

/* Tablas */

.table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
}

    .table thead {
        background: #f8fafc;
    }

    .table th {
        color: var(--muted);
        font-weight: 600;
        font-size: .9rem;
        padding: 1rem;
        text-align: left;
    }

    .table td {
        padding: 1rem;
        border-top: 1px solid var(--border);
    }

    .table tbody tr {
        transition: .2s ease;
    }

        .table tbody tr:hover {
            background: #f8fbff;
        }

.link-button {
    background: transparent;
    border: none;
    padding: 0;
    text-align: left;
    color: var(--primary);
    cursor: pointer;
    font-weight: 600;
}

.modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(2,6,23,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
}

.modal-card {
    background: white;
    padding: 1.25rem;
    border-radius: 12px;
    max-width: 520px;
    width: 90%;
    box-shadow: var(--shadow);
}

/* Dashboard cards */

.dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap: 1rem;
}

.dashboard-card {
    background: white;
    border-radius: var(--radius);
    padding: 1.5rem;
    box-shadow: var(--shadow);
}

    .dashboard-card h3 {
        margin: 0;
        color: var(--muted);
        font-size: .95rem;
    }

    .dashboard-card p {
        font-size: 2rem;
        font-weight: 700;
        margin-top: .5rem;
    }

/* Footer */

.app-footer {
    text-align: center;
    color: var(--muted);
    padding: 1rem;
}

/* Responsive */

@media (max-width: 900px) {

    .app-layout {
        flex-direction: column;
    }

    .app-nav {
        width: 100%;
    }
}

.field {
    margin-bottom: 1rem;
}

label {
    display: block;
    margin-bottom: .45rem;
    font-weight: 600;
    color: var(--text);
}

h2 {
    margin-top: 0;
    margin-bottom: 1rem;
    font-size: 1.8rem;
}